{
  "name": "technician-crm-he",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "npm start --prefix server",
    "dev": "vite",
    "dev:api": "npm run dev --prefix server",
    "dev:all": "concurrently -n api,web -c cyan,magenta \"npm run dev --prefix server\" \"vite\"",
    "build": "tsc -b && vite build",
    "build:mobile": "npm run build && npx cap sync",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync",
    "android:open": "npm run cap:sync && npx cap open android",
    "android:apk": "npm run cap:sync && cd android && gradlew.bat assembleDebug",
    "android:run": "npm run cap:sync && npx cap run android"
  },
  "dependencies": {
    "@capacitor-community/contacts": "^7.1.0",
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/share": "^7.0.4",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.5",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
