# Copy to .env.production (gitignored) before: npm run build && npx cap sync
# Use your deployed API URL + /api (same value you put in Render after deploy).
# Example: https://technician-crm-api.onrender.com/api
VITE_API_URL=

# Auto-login (no login screen). Same user as server seed — credentials are visible in the built JS bundle.
VITE_LOGIN_USERNAME=
VITE_LOGIN_PASSWORD=
