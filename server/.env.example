# Copy to .env — never commit .env
# Same Atlas cluster as easy-wedding is OK; use a dedicated database name, e.g. hvac-crm
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/hvac-crm?retryWrites=true&w=majority&appName=easyWeddingCluster
MONGO_DB_NAME=
JWT_SECRET=replace-with-long-random-secret
PORT=5050
