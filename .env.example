# Web dev: API on this machine
VITE_API_URL=http://localhost:5050/api

# Android (same Wi‑Fi as your PC): use your PC's LAN IP, not localhost.
# Example: VITE_API_URL=http://192.168.1.10:5050/api
# Then: npm run build && npx cap sync
#
# Or leave VITE_API_URL unset for production APK — the login screen lets you type
# the API URL once; it is saved on the device (localStorage).
